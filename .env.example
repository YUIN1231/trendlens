# ── PRIMARY: OpenWeb Ninja (FREE, no credit card) ────────────────────────
# 500 free requests · Sign up: https://app.openwebninja.com/signup
# Dashboard → API Keys → Create Key
OPENWEBNINJA_API_KEY=

# ── SECONDARY: Outscraper (free credits on signup, may need CC) ──────────
