# ── TERTIARY: Apify (requires $49/mo Pro for proxy) ─────────────────────
APIFY_API_TOKEN=

# ── Vercel Blob (auto-set when linked in Vercel Dashboard) ──────────────
BLOB_READ_WRITE_TOKEN=
